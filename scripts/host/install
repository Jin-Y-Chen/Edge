#!/usr/bin/env bash
# Make all scripts in host/ executable.
#
# First time after clone:
#   chmod +x host/install
#   ./host/install
#
# Or without chmod: bash host/install

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

for file in "$SCRIPT_DIR"/*; do
  [[ -f "$file" ]] || continue
  name="$(basename "$file")"
  chmod +x "$file"
  echo "chmod +x host/$name"
done

echo "Host install done."
