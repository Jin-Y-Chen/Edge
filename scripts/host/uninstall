#!/usr/bin/env bash
# Remove host scripts by deleting your Edge repo clone.
#
#   ./host/uninstall
#
# Deletes the repo folder and everything in it (including this script).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
REPO_NAME="$(basename "$REPO_ROOT")"

[[ -d "$REPO_ROOT/scripts/host" ]] || {
  echo "Does not look like the Edge repo: ${REPO_ROOT}" >&2
  exit 1
}

read -rp "Delete Edge repo at ${REPO_ROOT}? [y/N] " confirm
[[ "${confirm,,}" == "y" || "${confirm,,}" == "yes" ]] || { echo "Cancelled."; exit 0; }

cd "$(dirname "$REPO_ROOT")"
rm -rf "$REPO_NAME"
echo "Edge repo removed."
