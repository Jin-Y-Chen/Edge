#!/usr/bin/env bash
# Full teardown: reject all injections on edge, then delete host repo clone.
#
#   source ./host/uninstall [usb]   # required — cd ~ applies to your shell
#   ./host/uninstall [usb]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOST_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SCRIPTS_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
REPO_NAME="$(basename "$REPO_ROOT")"

# shellcheck source=../../config.sh
source "$SCRIPTS_ROOT/config.sh"
# shellcheck source=../function/helper.sh
source "$HOST_ROOT/function/helper.sh"

CATALOG="${SCRIPTS_ROOT}/catalog.list"

target="lan"
[[ "${1:-}" == "usb" ]] && target="usb"

[[ -d "$REPO_ROOT/scripts/host" ]] || {
  echo "Does not look like the Edge repo: ${REPO_ROOT}" >&2
  exit 1
}

echo "Step 1 — Edge device"
echo "  All injected solutions will be rejected from the Jetson."
echo ""
read -rp "Reject everything injected on edge? [y/N] " confirm_edge
[[ "${confirm_edge,,}" == "y" || "${confirm_edge,,}" == "yes" ]] || { echo "Cancelled."; exit 0; }

reject_all_on_edge "$CATALOG" "$target" 1

echo ""
echo "Step 2 — Host"
echo "  The Edge repo clone will be deleted:"
echo "    ${REPO_ROOT}"
echo ""
read -rp "Delete host repo clone? [y/N] " confirm_host
if [[ "${confirm_host,,}" != "y" && "${confirm_host,,}" != "yes" ]]; then
  echo "Edge cleaned. Host repo kept."
  cd ~
  exit 0
fi

(
  cd "$(dirname "$REPO_ROOT")"
  rm -rf "$REPO_NAME"
)

cd ~
echo "Host repo removed."
