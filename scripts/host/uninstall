#!/usr/bin/env bash
# Full teardown: reject all injections on edge, then delete host repo clone.
# Tries LAN and USB automatically to reach the Jetson.
#
#   source ./host/uninstall   # required — cd ~ applies to your shell
#   ./host/uninstall

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HOST_ROOT="$SCRIPT_DIR"
SCRIPTS_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
REPO_NAME="$(basename "$REPO_ROOT")"

# shellcheck source=../config.sh
source "$SCRIPTS_ROOT/config.sh"
# shellcheck source=function/helper.sh
source "$HOST_ROOT/function/helper.sh"

CATALOG="${SCRIPTS_ROOT}/catalog.list"

[[ $# -eq 0 ]] || {
  echo "Usage: source ./host/uninstall" >&2
  echo "No arguments — edge cleanup tries LAN (${BOARD_IP}) then USB (${BOARD_IP_USB})." >&2
  exit 1
}

[[ -d "$REPO_ROOT/scripts/host" ]] || {
  echo "Does not look like the Edge repo: ${REPO_ROOT}" >&2
  exit 1
}

echo "Step 1 — Edge device"
echo "  All injected solutions will be rejected from the Jetson."
echo "  Tries LAN (${BOARD_IP}) first, then USB (${BOARD_IP_USB})."
echo "  Catalog is updated after each successful removal."
echo ""
read -rp "Reject everything injected on edge? [y/N] " confirm_edge
[[ "${confirm_edge,,}" == "y" || "${confirm_edge,,}" == "yes" ]] || { echo "Cancelled."; exit 0; }

BOARD_SSH_PASSWORD=""
if load_catalog "$CATALOG"; then
  if ! read -rs -p "SSH password for ${BOARD_USER}@Jetson (used once for all rejections): " BOARD_SSH_PASSWORD; then
    echo "" >&2
    echo "Password input failed." >&2
    exit 1
  fi
  echo ""
  if [[ -z "$BOARD_SSH_PASSWORD" ]]; then
    echo "SSH password cannot be empty." >&2
    exit 1
  fi
fi

reject_all_for_uninstall "$CATALOG" "$BOARD_SSH_PASSWORD" || {
  unset BOARD_SSH_PASSWORD
  echo ""
  echo "Edge cleanup incomplete. Host repo was not removed." >&2
  exit 1
}
unset BOARD_SSH_PASSWORD

echo ""
echo "Step 2 — Host"
echo "  The Edge repo clone will be deleted:"
echo "    ${REPO_ROOT}"
echo ""
read -rp "Delete host repo clone? [y/N] " confirm_host
if [[ "${confirm_host,,}" != "y" && "${confirm_host,,}" != "yes" ]]; then
  echo "Host repo kept."
  cd ~
  exit 0
fi

(
  cd "$(dirname "$REPO_ROOT")"
  rm -rf "$REPO_NAME"
)

cd ~
echo "Host repo removed."
