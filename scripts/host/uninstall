#!/usr/bin/env bash
# Usage: source ./host/uninstall
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/function/host.sh"
host_init "${BASH_SOURCE[0]}"

[[ $# -eq 0 ]] || die "Usage: source ./host/uninstall (no arguments)"

[[ -d "$REPO_DIR/scripts/host" ]] || die "Not the Edge repo: ${REPO_DIR}"

echo "Step 1 — Edge device"
confirm_yes "Reject all injected scripts on edge? [y/N] " || { echo "Cancelled."; exit 0; }

trap board_session_end RETURN
if load_catalog "$CATALOG"; then
  pick_route || die "Could not reach board (LAN ${BOARD_IP}, USB ${BOARD_IP_USB})."
  if ! board_auth_ok "$BOARD_ROUTE"; then
    board_session_begin "$BOARD_ROUTE"
  fi
fi

reject_all_catalog "$CATALOG" "" 0 || {
  die "Edge cleanup incomplete. Host repo kept."
}

echo ""
echo "Step 2 — Host"
echo "Delete repo: ${REPO_DIR}"
confirm_yes "Delete host repo clone? [y/N] " || { echo "Host repo kept."; cd ~; exit 0; }

cd "$(dirname "$REPO_DIR")"
rm -rf "$(basename "$REPO_DIR")"
cd ~
echo "Host repo removed."
