#!/usr/bin/env bash
# Jetson AI agent skills: NVIDIA jetson-device-skills for Cursor.
# spawn git jetson_device_skills ~/jetson_device_skills
set -euo pipefail

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && {
  echo "Usage: ./device_skill [cursor|all|claude,codex,cursor]"
  exit 0
}

targets="${DEVICE_SKILL_TARGETS:-cursor}"
case "${1:-cursor}" in
  all) targets="claude,codex,cursor" ;;
  cursor|"") targets="cursor" ;;
  *) targets="$1" ;;
esac

command -v git >/dev/null || {
  sudo -n true 2>/dev/null || { echo "Sudo password required."; sudo -v; }
  sudo apt install -y git
}

clone_dir="${HOME}/jetson_device_skills"

if [[ -d "${clone_dir}/.git" ]]; then
  echo "Updating jetson-device-skills ..."
  git -C "$clone_dir" pull --ff-only
else
  echo "Cloning jetson-device-skills to ${clone_dir} ..."
  rm -rf "$clone_dir"
  git clone --depth 1 https://github.com/NVIDIA-AI-IOT/jetson-device-skills.git "$clone_dir"
fi

[[ -f "${clone_dir}/install.sh" ]] || { echo "install.sh missing in ${clone_dir}." >&2; exit 1; }

echo "Installing skills for ${targets} ..."
bash "${clone_dir}/install.sh" --targets "$targets"

echo "Restart Cursor agent (new chat), then: Use the Jetson diagnostic skill to inspect this device."
