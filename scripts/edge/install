#!/usr/bin/env bash
# Set up the edge bundle on this Jetson. Run after copying this folder over.
#
#   chmod +x install
#   ./install
#
# Or without chmod: bash install

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

for file in "$SCRIPT_DIR"/*; do
  [[ -f "$file" ]] || continue
  name="$(basename "$file")"
  [[ "$name" == "README.md" ]] && continue
  chmod +x "$file"
  echo "chmod +x $name"
done

echo "Edge bundle ready at ${SCRIPT_DIR}"
