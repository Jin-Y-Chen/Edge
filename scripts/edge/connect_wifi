#!/usr/bin/env bash
# Connect this Jetson to Wi-Fi. Run on the edge device.
#
#   ./connect_wifi              # scan, pick network, enter password
#   ./connect_wifi list         # show scan table
#   ./connect_wifi "SSID" pass  # direct connect

set -euo pipefail

SSID=""
PASSWORD=""

usage() {
  cat <<'EOF'
Connect Jetson to Wi-Fi (run on edge).

  ./connect_wifi                    interactive — scan, pick, password
  ./connect_wifi list               show networks visible to this board
  ./connect_wifi "SSID" "password"  direct connect

Get Wi-Fi password from Windows host (PowerShell):
  netsh wlan show profile name="SSID" key=clear
EOF
}

parse_wifi_list() {
  awk -F: '
    $1 != "" && $1 != "--" {
      if (!($1 in sig) || $2 + 0 > sig[$1] + 0) sig[$1] = $2
    }
    END { for (s in sig) printf "%s:%s\n", s, sig[s] }
  ' | sort -t: -k2 -nr
}

scan_wifi() {
  nmcli device wifi rescan 2>/dev/null || true
  sleep 2
  nmcli -t -f SSID,SIGNAL device wifi list
}

show_list() {
  echo "Scanning..."
  scan_wifi >/dev/null
  nmcli device wifi list
}

ensure_sudo() {
  if sudo -n true 2>/dev/null; then
    return 0
  fi
  echo "Sudo password required to configure Wi-Fi."
  sudo -v
}

connect_network() {
  local ssid="$1"
  local password="$2"
  local output
  local status=0

  ensure_sudo

  nmcli radio wifi on 2>/dev/null || true

  echo "Connecting to \"${ssid}\" ..."

  set +e
  output="$(sudo nmcli device wifi connect "$ssid" password "$password" 2>&1)"
  status=$?
  set -e

  if [[ $status -ne 0 ]]; then
    echo "Failed: could not connect to \"${ssid}\"." >&2
    [[ -n "$output" ]] && echo "$output" >&2
    echo "Check SSID, password, and signal strength, then try again." >&2
    return 1
  fi

  echo "Success: connected to \"${ssid}\"."
  [[ -n "$output" ]] && echo "$output"
  echo "IP address:"
  hostname -I || true
}

interactive_pick() {
  local -a entries=("$@")
  local count=${#entries[@]}

  if [[ $count -eq 0 ]]; then
    echo "No networks found." >&2
    return 1
  fi

  echo ""
  echo "Available networks:"
  local i=1
  for entry in "${entries[@]}"; do
    printf "  %2d) %-32s (%s%%)\n" "$i" "${entry%%:*}" "${entry#*:}"
    ((i++)) || true
  done
  echo ""

  local choice
  while true; do
    read -rp "Select network [1-${count}]: " choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= count )); then
      break
    fi
    echo "Invalid selection." >&2
  done

  SSID="${entries[$((choice - 1))]%%:*}"
  SSID="${SSID#"${SSID%%[![:space:]]*}"}"
  SSID="${SSID%"${SSID##*[![:space:]]}"}"

  if ! read -rs -p "Password for \"${SSID}\": " PASSWORD; then
    echo "" >&2
    echo "Password input failed." >&2
    return 1
  fi
  echo ""

  if [[ -z "$PASSWORD" ]]; then
    echo "Password cannot be empty." >&2
    return 1
  fi
}

interactive_connect() {
  local -a entries=()

  echo "Scanning Wi-Fi..."
  mapfile -t entries < <(scan_wifi | parse_wifi_list)
  interactive_pick "${entries[@]}"
  connect_network "$SSID" "$PASSWORD"
}

# --- main ---

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    list|ls)
      show_list
      exit 0
      ;;
    *)
      if [[ -z "$SSID" ]]; then
        SSID="$1"
      elif [[ -z "$PASSWORD" ]]; then
        PASSWORD="$1"
      else
        echo "Unexpected argument: $1" >&2
        exit 1
      fi
      ;;
  esac
  shift
done

if [[ -n "$SSID" && -n "$PASSWORD" ]]; then
  connect_network "$SSID" "$PASSWORD"
else
  interactive_connect
fi
